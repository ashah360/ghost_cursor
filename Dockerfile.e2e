# Reproduce the ghost_cursor e2e environment locally — real Hermes + real
# REST API (httpx), no mocks. Mirrors what the GitHub Actions e2e job does.
#
#   docker build -t ghost-cursor-e2e -f Dockerfile.e2e .
#   docker run --rm -e CURSOR_API_KEY=sk-... ghost-cursor-e2e
#
# (Or mount your key file / pass it however you prefer.)
FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        git curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# uv for fast, locked dep install
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Real Hermes core (the plugin imports hermes_constants + tools.* + hermes_cli.config)
RUN git clone --depth 1 https://github.com/NousResearch/hermes-agent /opt/hermes-agent
WORKDIR /opt/hermes-agent
RUN uv sync --frozen || uv sync || pip install -e .

# httpx (the REST+SSE transport layer; usually already a hermes dep)
RUN uv add httpx || uv pip install httpx

# pytest into the uv project env (it's not a Hermes dep)
RUN uv add --dev pytest || uv pip install pytest

# The plugin
COPY *.py /opt/hermes-agent/plugins/ghost_cursor/
# The unit test + its fixtures must sit together (test uses Path(__file__).parent/"fixtures")
COPY test_ghost_cursor_plugin.py /opt/hermes-agent/tests/plugins/test_ghost_cursor_plugin.py
COPY conftest.py /opt/hermes-agent/tests/plugins/conftest.py
COPY fixtures/ /opt/hermes-agent/tests/plugins/fixtures/
# The e2e suite
COPY tests/e2e/ /opt/hermes-agent/tests/plugins/e2e/
# Drop the stray copies the plugin glob pulled in
RUN rm -f /opt/hermes-agent/plugins/ghost_cursor/test_ghost_cursor_plugin.py \
          /opt/hermes-agent/plugins/ghost_cursor/conftest.py

ENV GHOST_CURSOR_E2E=1 \
    GHOST_CURSOR_TEST_MODEL=gpt-5.4-nano-low \
    GHOST_CURSOR_PLUGIN_INIT=/opt/hermes-agent/plugins/ghost_cursor/__init__.py \
    PYTHONPATH=/opt/hermes-agent

# Unit tests always; e2e only if CURSOR_API_KEY is provided at runtime.
CMD ["bash", "-lc", "uv run --with pytest pytest tests/plugins/test_ghost_cursor_plugin.py -q && uv run --with pytest pytest tests/plugins/e2e/test_e2e.py -q -v"]
